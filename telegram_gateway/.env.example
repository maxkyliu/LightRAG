# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=

# --- LightRAG backend (required) ---
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=
# Team id -> workspace name mapping: workspace = <prefix><team_id>
GATEWAY_WORKSPACE_PREFIX=team_
LIGHTRAG_REQUEST_TIMEOUT=120

# --- Gateway datastore ---
GATEWAY_DB_PATH=telegram_gateway.db

# --- Sessions / talk-events ---
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_TOKEN_CAP=6000

# --- Public URL fetch (SSRF-guarded) ---
FETCH_MAX_BYTES=52428800
FETCH_TIMEOUT_SECONDS=60
FETCH_MAX_REDIRECTS=3

# --- Speech-to-text (optional) ---
# STT_PROVIDER: "openai" (remote /audio/transcriptions) or "local" (in-process
# Whisper via transformers; install requirements-local-stt.txt + ffmpeg).
STT_PROVIDER=openai
# Remote (STT_PROVIDER=openai):
STT_ENDPOINT=
STT_API_KEY=
STT_MODEL=whisper-1
# Local Whisper Turbo (STT_PROVIDER=local): set STT_MODEL=turbo (or a size
# alias / full HF repo id). STT_LANGUAGE empty = auto-detect. STT_DEVICE empty
# = auto (cuda if available, else cpu).
# STT_MODEL=turbo
# STT_LANGUAGE=
# STT_DEVICE=

# --- Vision / OCR (optional; OpenAI-compatible /chat/completions) ---
VISION_ENDPOINT=
VISION_API_KEY=
VISION_MODEL=

# --- Talk-event summarizer (optional; OpenAI-compatible /chat/completions) ---
# Without this, conversation talk-events are skipped (default-deny).
SUMMARIZER_ENDPOINT=
SUMMARIZER_API_KEY=
SUMMARIZER_MODEL=
